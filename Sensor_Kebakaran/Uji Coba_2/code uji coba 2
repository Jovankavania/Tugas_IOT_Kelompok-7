#include <WiFi.h>
#include <WebServer.h>
#include "DHT.h"

// 1. PIN REVISI: DHT11 pindah ke D13 biar stabil
#define PIN_DHT    13    // Data DHT11 SEKARANG KE D13
#define PIN_MQ2    26    // Data MQ-2 tetap di D26
#define PIN_FLAME  25    // Data Flame tetap di D25

#define DHTTYPE DHT11
DHT dht(PIN_DHT, DHTTYPE);

// 2. Masukkan kembali nama hotspot dan password HP-mu di sini
const char* ssid = "wakwaw"; 
const char* password = "123456789"; 

WebServer server(80);

void handleRoot() {
  float kelembaban = dht.readHumidity();
  float suhu = dht.readTemperature();
  int statusAsap = digitalRead(PIN_MQ2);
  int statusApi = digitalRead(PIN_FLAME);

  // Perbaikan meta charset agar EMOJI tidak berubah jadi karakter alien
  String html = "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\">";
  html += "<style>html { font-family: Helvetica; display: inline-block; margin: 0px auto; text-align: center; background-color: #f0f2f5;}";
  html += ".card { background-color: white; box-shadow: 2px 2px 12px 1px rgba(0,0,0,0.1); padding: 20px; margin: 20px auto; max-width: 400px; border-radius: 10px;}";
  html += "h1 {color: #333333;} .value { font-size: 2rem; font-weight: bold; color: #007bff;}";
  html += ".status-safe { color: #28a745; font-weight: bold; font-size: 1.5rem; }";
  html += ".status-danger { color: #dc3545; font-weight: bold; font-size: 1.5rem; animation: blinker 1s linear infinite; }</style>";
  html += "<script>setInterval(function() { window.location.reload(); }, 2000);</script></head><body>";
  
  html += "<h1>🔥 MONITORING KEBAKARAN KELOMPOK 7 🔥</h1>";
  
  // Tampilan Suhu
  html += "<div class=\"card\"><h2>🌡️ Lingkungan</h2>";
  if (isnan(suhu) || isnan(kelembaban)) {
    html += "<p style=\"color:red; font-weight:bold;\">⚠️ Gagal membaca sensor DHT11!<br><small>Pastikan kabel data pas di D13 & VCC/GND kencang</small></p>";
  } else {
    html += "<p>Suhu: <span class=\"value\">" + String(suhu, 1) + " &deg;C</span></p>";
    html += "<p>Kelembaban: <span class=\"value\">" + String(kelembaban, 0) + " %</span></p>";
  }
  html += "</div>";

  // Tampilan Asap
  html += "<div class=\"card\"><h2>💨 Sensor Gas/Asap (MQ-2)</h2>";
  if (statusAsap == LOW) {
    html += "<p class=\"status-danger\">⚠️ TERDETEKSI ASAP! ⚠️</p>";
  } else {
    html += "<p class=\"status-safe\">✅ Aman</p>";
  }
  html += "</div>";

  // Tampilan Api
  html += "<div class=\"card\"><h2>🔥 Sensor Api (Flame)</h2>";
  if (statusApi == LOW) {
    html += "<p class=\"status-danger\">🚨 ADA API! AWAS! 🚨</p>";
  } else {
    html += "<p class=\"status-safe\">✅ Aman</p>";
  }
  html += "</div></body></html>";
  
  server.send(200, "text/html", html);
}

void setup() {
  Serial.begin(115200);
  dht.begin();
  pinMode(PIN_MQ2, INPUT);
  pinMode(PIN_FLAME, INPUT);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }
  
  server.on("/", handleRoot);
  server.begin();
}

void loop() {
  server.handleClient();
}
