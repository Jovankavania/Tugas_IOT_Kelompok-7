#include <WiFi.h>
#include <WebServer.h>
#include "DHT.h"

// 1. PIN SETTING ALL COMPONENT
#define PIN_BUZZER 12    
#define PIN_DHT    13    
#define PIN_MQ2    26    
#define PIN_FLAME  25    

#define DHTTYPE DHT11
DHT dht(PIN_DHT, DHTTYPE);

// KONEKSI WI-FI RUMAH
const char* ssid = "GUN_GUN"; 
const char* password = "wingun20"; 

WebServer server(80);

// 2. STRUKTUR MEMORI HISTORI (Maksimal 10 data terakhir)
const int MAX_DATA = 10;
float riwayat_suhu[MAX_DATA] = {0};
float riwayat_kelembaban[MAX_DATA] = {0};
String riwayat_asap[MAX_DATA] = {""};
String riwayat_api[MAX_DATA] = {""};
int indeks_data = 0;
unsigned long waktu_sebelumnya = 0;

// Variabel pengunci mendeteksi perubahan status darurat secara real-time
bool status_kebakaran_sebelumnya = false; 

// Fungsi untuk memasukkan 4 data sensor sekaligus ke dalam tabel log
void tambahRiwayat(float s, float k, int asap, int api) {
  // Jika suhu ekstrim, status di tabel akan otomatis ikut memberikan peringatan
  String status_asap = (asap == LOW) ? "⚠️ BAHAYA" : "✅ Aman";
  String status_api = (api == LOW || s >= 57.0) ? "🚨 API/PANAS!" : "✅ Aman";

  if (indeks_data >= MAX_DATA) {
    for (int i = 0; i < MAX_DATA - 1; i++) {
      riwayat_suhu[i] = riwayat_suhu[i + 1];
      riwayat_kelembaban[i] = riwayat_kelembaban[i + 1];
      riwayat_asap[i] = riwayat_asap[i + 1];
      riwayat_api[i] = riwayat_api[i + 1];
    }
    riwayat_suhu[MAX_DATA - 1] = s;
    riwayat_kelembaban[MAX_DATA - 1] = k;
    riwayat_asap[MAX_DATA - 1] = status_asap;
    riwayat_api[MAX_DATA - 1] = status_api;
  } else {
    riwayat_suhu[indeks_data] = s;
    riwayat_kelembaban[indeks_data] = k;
    riwayat_asap[indeks_data] = status_asap;
    riwayat_api[indeks_data] = status_api;
    indeks_data++;
  }
}

void handleRoot() {
  float kelembaban = dht.readHumidity();
  float suhu = dht.readTemperature();
  int statusAsap = digitalRead(PIN_MQ2);
  int statusApi = digitalRead(PIN_FLAME);

  if (isnan(suhu) || isnan(kelembaban)) {
    suhu = 0;
    kelembaban = 0;
  }

  // 🔥 TAMBAHAN LOGIKA ALARM: Ditambah filter suhu ekstrim >= 57 derajat Celsius
  if (statusAsap == LOW || statusApi == LOW || suhu >= 57.0) {
    digitalWrite(PIN_BUZZER, HIGH); 
  } else {
    digitalWrite(PIN_BUZZER, LOW);  
  }

